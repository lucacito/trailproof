{
    "name": "trailproof/trailproof",
    "description": "Accessibility remediation and audit trail for Divi",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "symfony/css-selector": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Trailproof\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Trailproof\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
